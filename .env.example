# Optional. Leave empty or unset to run WebMPC without PocketBase sync.
# For local Docker Compose on the same machine:
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# For Android Chrome or another device in a Tailnet, rebuild the frontend with
# the HTTPS URL that the browser can reach, for example:
# VITE_POCKETBASE_URL=https://your-tailnet-host.example.ts.net
